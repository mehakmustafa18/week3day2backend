{
  "info": {
    "name": "Task Manager API v2",
    "description": "Complete collection with Auth + Tasks CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/users/register" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/users/login" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/users/profile" }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/tasks" }
          }
        },
        {
          "name": "Get All Tasks (Filter by title)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/tasks?title=learn" }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/tasks/TASK_ID_HERE" }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Learn MongoDB\",\n  \"completed\": false\n}"
            },
            "url": { "raw": "http://localhost:3000/api/tasks" }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Learn MongoDB (Updated)\",\n  \"completed\": true\n}"
            },
            "url": { "raw": "http://localhost:3000/api/tasks/TASK_ID_HERE" }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/tasks/TASK_ID_HERE" }
          }
        },
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }],
            "url": { "raw": "http://localhost:3000/api/tasks/stats" }
          }
        }
      ]
    }
  ]
}
